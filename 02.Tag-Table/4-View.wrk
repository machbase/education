{"data":[{"id":"1778055087092945","contents":"# 1. 테이블 생성","height":37,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778055114250637","contents":"drop table customer;\r\nCREATE LOOKUP TABLE customer (\r\n    id INTEGER PRIMARY KEY,\r\n    name VARCHAR(20),\r\n    city VARCHAR(20),\r\n    amount INTEGER\r\n);","height":159,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1778055131871428","contents":"desc customer;","height":27,"lineHeight":19,"minimal":false,"type":"shell","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778055190962973","contents":"# 2. 데이터 입력 및 조회","height":55,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"177805521468557","contents":"-- 데이터 입력\r\ninsert into customer values (1, 'John', 'Newyork', 100000);\r\n\r\ninsert into customer values (2, 'Susan', 'Miami', 90000);\r\n\r\ninsert into customer values (3, 'Steve', 'Houston', 87000);\r\n\r\ninsert into customer values (4, 'Jenny', 'Chicago', 110000);\r\n\r\n-- RAW 데이터 조회\r\nselect * from customer;","height":245,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1778055302720178","contents":"# 3.VIEW 생성","height":27,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778055288125611","contents":"--View 생성\r\ndrop view v_customer;\r\nCREATE VIEW v_customer AS\r\nSELECT id, name, city, amount\r\nFROM customer;","height":101,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1778055454654243","contents":"# 4.VIEW 조회","height":42,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778055436009684","contents":"--View 조회\r\nSELECT * FROM v_customer;\r\nSELECT name, city FROM v_customer where id = 1;","height":81,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"177805554300110","contents":"# 5.VIEW 정의 변경","height":46,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"177805556580224","contents":"--View 생성 \r\nCREATE VIEW v_customer_amount AS\r\nSELECT id, amount\r\nFROM customer;\r\n\r\n--변경 전 조회\r\nSELECT * FROM v_customer_amount;\r\n\r\n--View 정의 변경\r\nCREATE OR REPLACE VIEW v_customer_amount AS\r\nSELECT id, name, amount / 12 AS amount\r\nFROM customer\r\nWHERE id > 2;\r\n\r\n--변경 후 조회\r\nSELECT * FROM v_customer_amount;\r\nSELECT name, amount FROM v_customer_amount where id = 3;","height":348,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1778055756360555","contents":"# 6.VIEW 삭제","height":35,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778055750681460","contents":"Drop VIEW v_customer_amount;\r\nselect * from v_customer_amount;\r\nDrop VIEW v_customer;","height":75,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1778142911212557","contents":"# 7.VIEW 활용","height":51,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778142933834815","contents":"DROP VIEW app_view;\r\nCREATE VIEW app_view AS\r\nSELECT name,\r\n       time,\r\n       extract_bit(frame, 0) AS bit0,\r\n       extract_ulong(frame, 0, 16) AS u16,\r\n       extract_long(frame, 0, 16) AS s16,\r\n       extract_float(frame, 0) AS f32,\r\n       extract_scaled_double(frame, 0, 12, 0, 0.5, 0.5) AS sd12\r\nFROM daq_data;","height":215,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1778143056819394","contents":"SELECT name, time, bit0, u16, s16, f32, sd12\r\nFROM app_view\r\nWHERE name = 'SENSOR1'\r\n  AND time >= TO_DATE('2026-04-15 09:00:00')\r\n  AND time <  TO_DATE('2026-04-15 09:01:00')\r\nORDER BY time;","height":128,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false}]}