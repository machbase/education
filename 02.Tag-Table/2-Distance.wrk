{"data":[{"id":"1777540016070812","contents":"# 1. 테이블 생성","height":200,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1777276556518815","contents":"drop table distance_sensor;\r\ncreate tag table distance_sensor ( name varchar(32) primary key, odometer_m double base distance, value double, quality integer) \r\ntag_partition_count=1;","height":70,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1777276654670881","contents":"-- 테이블 구조 확인\r\ndesc distance_sensor;","height":52,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1777540055878292","contents":"# 2. 데이터 로딩","height":200,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1777343428111766","contents":"CSV(file(\"/education/02.Tag-Table/distance_sensor_data_1M.csv\"), logProgress(100000))\r\nMAPVALUE(0, strTrimSpace(value(0)), \"name\")\r\nMAPVALUE(1, parseFloat(value(1)), \"odometer_m\")\r\nMAPVALUE(2, parseFloat(value(2)), \"value\")\r\nMAPVALUE(3, parseFloat(value(3)), \"quality\")\r\nAPPEND(table(\"distance_sensor\"))","height":126,"lineHeight":19,"minimal":false,"type":"tql","tqlType":"text","lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1777540081685945","contents":"# 3. 데이터 조회","height":200,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1777276705222354","contents":"-- 건수 조회\r\nselect count(*) from distance_sensor;\r\n\r\n-- distance 범위 조회\r\nselect min(odometer_m), max(odometer_m) from distance_sensor;\r\n\r\n-- RAW 데이터 조회\r\nselect * from distance_sensor limit 10;\r\n","height":175,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false},{"id":"177854884671298","contents":"-- 거리 기준 조회 조건 검색\r\nSELECT * FROM distance_sensor \r\nWHERE name = 'SENSOR_05' AND odometer_m between 1000 and 2000 limit 10;\r\n\r\nSELECT name, min(value), max(value), avg(value), count(value) FROM distance_sensor \r\nWHERE odometer_m > 5000 and odometer_m <= 10000\r\nGROUP BY name\r\nORDER BY name asc; ","height":172,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false},{"id":"17772769957281","contents":"-- 거리축 기준 값 조회\r\n-- 500미터 기준\r\nSELECT TRUNC(odometer_m / 500, 0) * 500 AS dist_bucket,\r\n       COUNT(*)                         AS sample_count,\r\n       MIN(value)                       AS min_v,\r\n       MAX(value)                       AS max_v,\r\n       AVG(value)                       AS avg_v\r\n FROM distance_sensor\r\n WHERE name = 'SENSOR_01'\r\n GROUP BY TRUNC(odometer_m / 500, 0) * 500\r\n ORDER BY dist_bucket;","height":220,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1777343548186658","contents":" -- 1000미터 기준\r\n SELECT TRUNC(odometer_m / 1000, 0) * 1000 AS dist_bucket,\r\n       COUNT(*)                         AS sample_count,\r\n       MIN(value)                       AS min_v,\r\n       MAX(value)                       AS max_v,\r\n       AVG(value)                       AS avg_v\r\n FROM distance_sensor\r\n WHERE name = 'SENSOR_03'\r\n GROUP BY TRUNC(odometer_m / 1000, 0) * 1000\r\n ORDER BY dist_bucket;","height":200,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1777343566197594","contents":"-- 5000미터 기준\r\nSELECT TRUNC(odometer_m / 5000, 0) * 5000 AS dist_bucket,\r\n       COUNT(*)                         AS sample_count,\r\n       MIN(value)                       AS min_v,\r\n       MAX(value)                       AS max_v,\r\n       AVG(value)                       AS avg_v\r\n FROM distance_sensor\r\n WHERE name = 'SENSOR_05'\r\n GROUP BY TRUNC(odometer_m / 5000, 0) * 5000\r\n ORDER BY dist_bucket;","height":200,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1777343582277347","contents":"-- 10000미터 기준\r\nSELECT TRUNC(odometer_m / 10000, 0) * 10000 AS dist_bucket,\r\n       COUNT(*)                         AS sample_count,\r\n       MIN(value)                       AS min_v,\r\n       MAX(value)                       AS max_v,\r\n       AVG(value)                       AS avg_v\r\n FROM distance_sensor\r\n WHERE name = 'SENSOR_07'\r\n GROUP BY TRUNC(odometer_m / 10000, 0) * 10000\r\n ORDER BY dist_bucket;","height":200,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"177804706635240","contents":"-- 50000미터 기준\r\nSELECT \r\nTRUNC(odometer_m / 50000, 0) * 50000 AS dist_bucket,\r\n       COUNT(*)                         AS sample_count,\r\n       MIN(value)                       AS min_v,\r\n       MAX(value)                       AS max_v,\r\n       AVG(value)                       AS avg_v\r\n FROM distance_sensor\r\n WHERE name = 'SENSOR_10'\r\n GROUP BY TRUNC(odometer_m / 50000, 0) * 50000\r\n ORDER BY dist_bucket;","height":227,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false},{"id":"1778047234680229","contents":"--10만 미터 기준\r\nSELECT TRUNC(odometer_m / 100000, 0) * 100000 AS dist_bucket,\r\n       COUNT(*)                         AS sample_count,\r\n       MIN(value)                       AS min_v,\r\n       MAX(value)                       AS max_v,\r\n       AVG(value)                       AS avg_v\r\n FROM distance_sensor\r\n WHERE name = 'SENSOR_09'\r\n GROUP BY TRUNC(odometer_m / 100000, 0) * 100000\r\n ORDER BY dist_bucket;","height":207,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false}]}