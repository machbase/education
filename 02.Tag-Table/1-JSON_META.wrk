{"data":[{"id":"1778140266069745","contents":"# 1. 테이블 생성","height":41,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778048478758793","contents":"drop table ships;\r\ncreate tag table ships ( name varchar(20) primary key, time datetime basetime, value double)\r\nmetadata ( info JSON INDEX('name', 'ship.status') );","height":81,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false},{"id":"1778140218473923","contents":"desc ships;","height":44,"lineHeight":19,"minimal":false,"type":"shell","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778140321632143","contents":"# 2. 메타 입력 및 조회","height":200,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778140381684741","contents":"-- 메타데이터 입력\r\ninsert into ships metadata values \r\n( 'SHIP_001', '{\"name\":\"alpha\",\"ship\":{\"status\":\"READY\"}}');\r\n\r\n-- 메타데이터 조회\r\nselect * from _ships_meta;\r\n\r\n--데이터 조회\r\nselect * from ships;","height":190,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1778140339559493","contents":"# 3. 데이터 입력 및 조회","height":200,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778140404691454","contents":"--데이터 입력\r\ninsert into ships values ( 'SHIP_001', sysdate, 2.3456 );\r\n\r\n--데이터 조회\r\nselect * from ships; -- {\"name\":\"alpha\",\"ship\":{\"status\":\"READY\"}}\r\nselect name, time, value from ships where info->'$.ship.status' = 'READY';","height":141,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1778230887355528","contents":"# 4. 메타 데이터 업데이트","height":50,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778230892804992","contents":"--update\r\nUPDATE ships METADATA SET info = JSON_SET_JSON(info, '$.owner', '{\"name\":\"abcd\", \"team\":\"planning\"}') WHERE name = 'SHIP_001';\r\n\r\n--데이터 조회\r\nselect * from ships;\r\nselect name, time, value from ships where info->'$.owner.team' = 'planning';","height":132,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true}]}