{"data":[{"id":"1777538959885235","contents":"# 1. 테이블 생성","height":200,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1777538908480316","contents":"drop table daq_data;\r\ncreate tag table daq_data(name varchar(20) primary key, time datetime basetime, frame binary(32));","height":54,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1777539084833732","contents":"desc daq_data;","height":34,"lineHeight":19,"minimal":false,"type":"shell","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1777539190768555","contents":"# 2. 데이터 로딩","height":30,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778133762465368","contents":"--SAMPLE DATA\r\nSENSOR1,2026-04-15 09:00:00,cc16d8aed82148eaccf48b7b07d03ab3\r\nSENSOR2,2026-04-15 09:00:00,0e7c2d3508fc25089b9afd0b2b942a93\r\nSENSOR3,2026-04-15 09:00:00,f277d5490b05d2c761fca5184f18c196\r\nSENSOR4,2026-04-15 09:00:00,5bebad1ee982a177b3115b62edbbbc0d\r\nSENSOR5,2026-04-15 09:00:00,b2b5341de811e585abdc23d57d376283","height":127,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1777539128332934","contents":"CSV(file(\"/education/02.Tag-Table/daq_sample.csv\"), logProgress(1000))\r\nMAPVALUE(0, strTrimSpace(value(0)), \"name\")\r\nMAPVALUE(1, parseTime(value(1),\"DEFAULT\", tz(\"local\")))\r\nMAPVALUE(2, (value(2)), \"frame\")\r\nINSERT(\"name\", \"time\", \"frame\", table(\"daq_data\"))","height":152,"lineHeight":19,"minimal":false,"type":"tql","tqlType":"text","lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1777539221675683","contents":"# 3. 데이터 조회","height":200,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1777539174390109","contents":"--bit 포맷으로 조회\r\nselect name, 'bit_value', extract_bit(frame, 13) from daq_data where name = 'SENSOR10' limit 10;\r\n\r\n--ulong 포맷으로 조회\r\nselect name, 'ulong_1_32', extract_ulong(frame, 1, 32) from daq_data where name = 'SENSOR10' limit 10;\r\n\r\n--long 포맷으로 조회\r\nselect 'long_5_32', extract_long(frame, 5, 32) from daq_data where name = 'SENSOR5' limit 10;\r\n\r\n--float 포맷으로 조회\r\nselect 'float', extract_float(frame, 8) from daq_data where name = 'SENSOR8' limit 10;\r\n\r\n--double 포맷으로 조회\r\nselect 'double', extract_double(frame, 12) from daq_data where name = 'SENSOR10' limit 10;\r\n\r\n--scaled_double 포맷으로 조회\r\nselect 'u8', extract_scaled_double(frame, 0, 20, 0, 0.01, -10) from daq_data where name = 'SENSOR3' limit 10;","height":338,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false}]}