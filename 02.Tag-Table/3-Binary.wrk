{"data":[{"id":"1777538959885235","contents":"# 1. 테이블 생성","height":200,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1777538908480316","contents":"drop table daq_data;\r\ncreate tag table daq_data(name varchar(20) primary key, time datetime basetime, frame binary(32));","height":54,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1777539084833732","contents":"desc daq_data;","height":34,"lineHeight":19,"minimal":false,"type":"shell","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1777539190768555","contents":"# 2. 데이터 로딩","height":30,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778133762465368","contents":"--SAMPLE DATA\r\nSENSOR1,2026-04-15 09:00:00,0x070100000040000000cac4b941996584ebf73890400d00\r\nSENSOR2,2026-04-15 09:00:00,0x030200000062000000016bc74170bcaba2fc838f401a00\r\nSENSOR3,2026-04-15 09:00:00,0x0303000000560000004487c2413f8c46c20f768e402700\r\nSENSOR4,2026-04-15 09:00:00,0x0104000000210000004766ad41043bac6e1cc78d403400\r\nSENSOR5,2026-04-15 09:00:00,0x0005000000ddfffffffbf791413612d1d56ac98d404100","height":127,"lineHeight":19,"minimal":false,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1777539128332934","contents":"CSV(file(\"/education/02.Tag-Table/daq_sample.csv\"), logProgress(1000))\r\nMAPVALUE(0, strTrimSpace(value(0)), \"name\")\r\nMAPVALUE(1, parseTime(value(1),\"DEFAULT\", tz(\"local\")))\r\nMAPVALUE(2, (value(2)), \"frame\")\r\nINSERT(\"name\", \"time\", \"frame\", table(\"daq_data\"))","height":152,"lineHeight":19,"minimal":false,"type":"tql","tqlType":"text","lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1777539221675683","contents":"# 3. 데이터 조회","height":200,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1777539174390109","contents":"--포맷 없이 조회\r\nselect * from daq_data limit 10;\r\n\r\n--bit 포맷으로 조회\r\nselect name, 'bit_value', extract_bit(frame, 13) from daq_data where name = 'SENSOR10' limit 10;\r\n\r\n--ulong 포맷으로 조회\r\nselect name, 'ulong_1_32', extract_ulong(frame, 1, 32) from daq_data where name = 'SENSOR10' limit 10;\r\n\r\n--long 포맷으로 조회\r\nselect 'long_5_32', extract_long(frame, 5, 32) from daq_data where name = 'SENSOR5' limit 10;\r\n\r\n--float 포맷으로 조회\r\nselect 'float', extract_float(frame, 3) from daq_data where name = 'SENSOR8' limit 10;\r\n\r\n--double 포맷으로 조회\r\nselect 'double', extract_double(frame, 13) from daq_data where name = 'SENSOR2' limit 10;\r\n\r\n--scaled_double 포맷으로 조회\r\nselect 'u8', extract_scaled_double(frame, 0, 20, 0, 0.01, -10) from daq_data where name = 'SENSOR3' limit 10;","height":418,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false}]}