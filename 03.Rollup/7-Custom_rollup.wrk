{"data":[{"id":"1777449015193645","contents":"# 1. 테이블 생성","height":200,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1777447388865475","contents":"drop table stock_tick cascade;\r\ncreate tag table if not exists stock_tick (\r\n    code      varchar(20) primary key,\r\n    time      datetime basetime,\r\n    price     double,\r\n    volume    double,\r\n    bid_price double,\r\n    ask_price double\r\n)tag_partition_count=1;","height":192,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1778045224942310","contents":"desc stock_tick;","height":36,"lineHeight":19,"minimal":false,"type":"shell","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1777447438354776","contents":"drop table STOCK_ROLLUP_1S cascade;\r\ncreate tag table if not exists stock_rollup_1s (\r\n    code       varchar(20) primary key,\r\n    time       datetime basetime,\r\n    sum_price  double,\r\n    sum_volume double,\r\n    sum_bid    double,\r\n    sum_ask    double,\r\n    cnt        integer,\r\n    open       double,\r\n    open_time  datetime,\r\n    close      double,\r\n    close_time datetime,\r\n    high       double,\r\n    low        double\r\n)tag_partition_count=1;","height":326,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1777447451657812","contents":"drop table STOCK_ROLLUP_1M cascade;\r\ncreate tag table if not exists stock_rollup_1m (\r\n    code       varchar(20) primary key,\r\n    time       datetime basetime,\r\n    sum_price  double,\r\n    sum_volume double,\r\n    sum_bid    double,\r\n    sum_ask    double,\r\n    cnt        integer,\r\n    open       double,\r\n    open_time  datetime,\r\n    close      double,\r\n    close_time datetime,\r\n    high       double,\r\n    low        double\r\n)tag_partition_count=1;","height":321,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"177744746509333","contents":"drop table STOCK_ROLLUP_1H cascade;\r\ncreate tag table if not exists stock_rollup_1h (\r\n    code       varchar(20) primary key,\r\n    time       datetime basetime,\r\n    sum_price  double,\r\n    sum_volume double,\r\n    sum_bid    double,\r\n    sum_ask    double,\r\n    cnt        integer,\r\n    open       double,\r\n    open_time  datetime,\r\n    close      double,\r\n    close_time datetime,\r\n    high       double,\r\n    low        double\r\n)tag_partition_count=1;","height":318,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1777447576342506","contents":"create rollup rollup_stock_1s\r\ninto (stock_rollup_1s)\r\nas (\r\n    select \r\n        code,\r\n        date_trunc('second', time) as time,\r\n        sum(price) as sum_price,\r\n        sum(volume) as sum_volume,\r\n        sum(bid_price) as sum_bid,\r\n        sum(ask_price) as sum_ask,\r\n        count(*) as cnt,\r\n        first(time, price) as open,\r\n        min(time) as open_time,\r\n        last(time, price) as close,\r\n        max(time) as close_time,\r\n        max(price) as high,\r\n        min(price) as low\r\n    from stock_tick\r\n    group by code, time\r\n)\r\ninterval 1 sec;","height":413,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1777447620786894","contents":"create rollup rollup_stock_1m\r\ninto (stock_rollup_1m)\r\nas (\r\n    select\r\n        code,\r\n        date_trunc('minute', time) as time,\r\n        sum(sum_price) as sum_price,\r\n        sum(sum_volume) as sum_volume,\r\n        sum(sum_bid) as sum_bid,\r\n        sum(sum_ask) as sum_ask,\r\n        sum(cnt) as cnt,\r\n        first(open_time, open) as open,\r\n        min(open_time) as open_time,\r\n        last(close_time, close) as close,\r\n        max(close_time) as close_time,\r\n        max(high) as high,\r\n        min(low) as low\r\n    from stock_rollup_1s\r\n    group by code, time\r\n)\r\ninterval 1 min;","height":414,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1777447648393290","contents":"create rollup rollup_stock_1h\r\ninto (stock_rollup_1h)\r\nas (\r\n    select\r\n        code,\r\n        date_trunc('hour', time) as time,\r\n        sum(sum_price) as sum_price,\r\n        sum(sum_volume) as sum_volume,\r\n        sum(sum_bid) as sum_bid,\r\n        sum(sum_ask) as sum_ask,\r\n        sum(cnt) as cnt,\r\n        first(open_time, open) as open,\r\n        min(open_time) as open_time,\r\n        last(close_time, close) as close,\r\n        max(close_time) as close_time,\r\n        max(high) as high,\r\n        min(low) as low\r\n    from stock_rollup_1m\r\n    group by code, time\r\n)\r\ninterval 1 hour;","height":405,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"177744770392337","contents":"# 2. 데이터 로딩","height":34,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778134013181950","contents":"--SAMPLE DATA\r\n\"MO\",2026-05-06 09:54:00,99.7043,1015.15,99.652,99.7557\r\n\"MO\",2026-05-06 09:54:00,99.6196,1172.72,99.552,99.676\r\n\"MO\",2026-05-06 09:54:01,100.104,1020.45,100.039,100.166\r\n\"MO\",2026-05-06 09:54:01,100.317,1137.67,100.265,100.374\r\n\"MO\",2026-05-06 09:54:02,99.6329,1021.11,99.5821,99.6902","height":135,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1777449133349568","contents":"CSV(file(\"/education/03.Rollup/stock_sample.csv\"), logProgress(1000))\r\nMAPVALUE(0, strTrimSpace(value(0)), \"code\")\r\nMAPVALUE(1, parseTime(value(1),\"DEFAULT\", tz(\"local\")))\r\nMAPVALUE(2, parseFloat(value(2)), \"price\")\r\nMAPVALUE(3, parseFloat(value(3)), \"volume\")\r\nMAPVALUE(4, parseFloat(value(4)), \"bid_price\")\r\nMAPVALUE(5, parseFloat(value(5)), \"ask_price\")\r\nAPPEND(table(\"stock_tick\"))","height":163,"lineHeight":19,"minimal":false,"type":"tql","tqlType":"text","lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1777449171645358","contents":"# 3. 데이터 조회","height":200,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778046559857487","contents":"--데이터 전체 건수\r\nselect count(*) from stock_tick;\r\n--데이터 범위 조회\r\nselect min(time), max(time) from stock_tick;","height":95,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1778046592463534","contents":"--RAW 데이터 조회\r\nselect * from stock_tick limit 10;","height":53,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false},{"id":"1778041773341177","contents":"--5분 사용자정의 롤업 조회\r\nSELECT\r\n    DATE_BIN('minute', time, 5) as mtime,\r\n    FIRST(open_time, open) as open,\r\n    LAST(close_time, close) as close,\r\n    MAX(high) as high,\r\n    MIN(low) as low,\r\n    SUM(sum_price) / SUM(cnt) as avg_price,\r\n    SUM(sum_volume) as total_volume,\r\n    SUM(sum_bid) / SUM(cnt) as avg_bid,\r\n    SUM(sum_ask) / SUM(cnt) as avg_ask\r\nFROM stock_rollup_1m\r\nWHERE code = 'MO'\r\nAND time >= to_date('2026-05-06 09:50:00')\r\nAND time <  to_date('2026-05-06 11:49:59')\r\n--AND time >= DATE_BIN('minute', SYSDATE, 5) - 2h\r\n--AND time <  DATE_BIN('minute', SYSDATE, 5) - 5s\r\nGROUP BY mtime\r\nORDER BY mtime\r\nUNION ALL\r\nSELECT\r\n    DATE_BIN('minute', time, 5) as mtime,\r\n    FIRST(open_time, open) as open,\r\n    LAST(close_time, close) as close,\r\n    MAX(high) as high,\r\n    MIN(low) as low,\r\n    SUM(sum_price) / SUM(cnt) as avg_price,\r\n    SUM(sum_volume) as total_volume,\r\n    SUM(sum_bid) / SUM(cnt) as avg_bid,\r\n    SUM(sum_ask) / SUM(cnt) as avg_ask\r\nFROM stock_rollup_1s\r\nWHERE code = 'MO'\r\nAND time >= to_date('2026-05-06 11:50:00')\r\n--AND time >= DATE_BIN('minute', SYSDATE, 5) - 5m\r\nGROUP BY mtime\r\nORDER BY mtime;","height":718,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false}]}
