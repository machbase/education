{"data":[{"id":"1778050704416836","contents":"# 1. 테이블 생성","height":37,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778050746935875","contents":"drop table tag_json_delta cascade;\r\ncreate tag table tag_json_delta (\r\n    name varchar(20) primary key,\r\n    time datetime basetime,\r\n    value json summarized\r\n)\r\nwith rollup extension tag_partition_count=1;","height":149,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1778050837594399","contents":"desc tag_json_delta;\r\nshow tables -a;","height":42,"lineHeight":19,"minimal":false,"type":"shell","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778050884312945","contents":"# 2. 데이터 로딩","height":41,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778135173658268","contents":"--SAMPLE DATA\r\nDEVICE_01,2026-05-01 00:00:00.000,\"{\"\"device\"\": {\"\"id\"\": \"\"DEVICE_01\"\", \"\"status\"\": \"\"FAIL\"\"}, \"\"metrics\"\": {\"\"temperature\"\": 56.83, \"\"pressure\"\": 2.207, \"\"vibration\"\": 3.341}, \"\"event\"\": {\"\"seq\"\": 0, \"\"timestamp\"\": \"\"2026-05-01T00:00:00\"\"}, \"\"diagnostics\"\": {\"\"cpu\"\": {\"\"core1\"\": 9.972708910559069, \"\"core2\"\": 92.67545279219492}, \"\"memory\"\": {\"\"used\"\": 10668, \"\"free\"\": 11046}}}\"\r\nDEVICE_01,2026-05-01 00:00:00.200,\"{\"\"device\"\": {\"\"id\"\": \"\"DEVICE_01\"\", \"\"status\"\": \"\"FAIL\"\"}, \"\"metrics\"\": {\"\"temperature\"\": 70.85, \"\"pressure\"\": 1.472, \"\"vibration\"\": 2.662}, \"\"event\"\": {\"\"seq\"\": 1, \"\"timestamp\"\": \"\"2026-05-01T00:00:00.200000\"\"}}\"\r\nDEVICE_01,2026-05-01 00:00:00.400,\"{\"\"device\"\": {\"\"id\"\": \"\"DEVICE_01\"\", \"\"status\"\": \"\"WARN\"\"}, \"\"metrics\"\": {\"\"temperature\"\": 93.1, \"\"pressure\"\": 1.111, \"\"vibration\"\": 0.87}, \"\"event\"\": {\"\"seq\"\": 2, \"\"timestamp\"\": \"\"2026-05-01T00:00:00.400000\"\"}}\"","height":100,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1778050935497791","contents":"CSV(file(\"/EDU202605/json_sample.csv\"), logProgress(100000))\r\nMAPVALUE(0, strTrimSpace(value(0)), \"name\")\r\nMAPVALUE(1, parseTime(value(1),\"DEFAULT\", tz(\"local\")))\r\nMAPVALUE(2, value(2), \"value\")\r\nAPPEND(table(\"tag_json_delta\"))","height":112,"lineHeight":19,"minimal":false,"type":"tql","tqlType":"text","lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778051187809824","contents":"# 3. 데이터 조회","height":43,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778051219454497","contents":"-- 조회전 rollup 강제 생성\r\nexec rollup_force;\r\n\r\n-- 데이터 건수 및 범위 \r\nselect count(*) from tag_json_delta;\r\nselect min(time), max(time) from tag_json_delta;\r\nselect * from _tag_json_delta_meta;","height":140,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":true},{"id":"1778051393338776","contents":"--RAW data 조회\r\nselect * from tag_json_delta limit 10;","height":70,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false},{"id":"1778052355366796","contents":"--JSON data 조회\r\nselect name, time, value->'$.log.messages' from tag_json_delta where name = 'DEVICE_02' and value->'$.log.messages' is not null limit 10;\r\nselect name, time, value->'$.log.messages[4]' from tag_json_delta where name = 'DEVICE_02' and value->'$.log.messages' is not null limit 10;\r\nselect time, (value->'$.metrics.temperature') as temp from tag_json_delta where name = 'DEVICE_01'\r\nand time >= to_date('2026-05-01 00:00:00') and time < to_date('2026-05-01 00:00:05');","height":113,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false},{"id":"1778136331250203","contents":"# 4. JSON Rollup data 조회","height":45,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778136382449637","contents":"--30분 기준 2초당 통계 조회\r\nselect rollup('sec', 2, time) as mtime,\r\nmin(value), max(value),avg(value),sum(value),count(value),first(time, value), last(time, value) from tag_json_delta\r\nwhere name = 'DEVICE_01' and time >= to_date('2026-05-01 00:00:00') and time < to_date('2026-05-01 00:00:30')\r\ngroup by mtime order by mtime;","height":130,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false},{"id":"1778137111137135","contents":"--1시간 30분 기준 10초당 통계 조회\r\nselect rollup('sec', 10, time) as mtime,\r\nmin(value), max(value),avg(value),sum(value),count(value),first(time, value), last(time, value) from tag_json_delta \r\nwhere name = 'DEVICE_01' and time >= to_date('2026-05-01 00:00:00') and time < to_date('2026-05-01 00:01:30')\r\ngroup by mtime order by mtime;","height":126,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false},{"id":"1778137110390168","contents":"--1시간 기준 5분당 통계 조회\r\nselect rollup('min', 5, time) as mtime,\r\nmin(value), max(value),avg(value),sum(value),count(value),first(time, value), last(time, value) from tag_json_delta\r\nwhere name = 'DEVICE_01' and time >= to_date('2026-05-01 00:00:00') and time < to_date('2026-05-01 01:00:00')\r\ngroup by mtime order by mtime;","height":125,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false},{"id":"1778137109740848","contents":"--6시간 기준 20분당 통계 조회\r\nselect rollup('min', 20, time) as mtime,\r\nmin(value), max(value),avg(value),sum(value),count(value),first(time, value), last(time, value) from tag_json_delta \r\nwhere name = 'DEVICE_01' and time >= to_date('2026-05-01 00:00:00') and time < to_date('2026-05-01 06:00:00')\r\ngroup by mtime order by mtime;","height":120,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false},{"id":"1778137108735724","contents":"--1일 기준 3시간당 통계 조회\r\nselect rollup('hour', 3, time) as mtime,\r\nmin(value), max(value),avg(value),sum(value),count(value),first(time, value), last(time, value) from tag_json_delta \r\nwhere name = 'DEVICE_01' and time >= to_date('2026-05-01 00:00:00') and time < to_date('2026-05-02 00:00:00')\r\ngroup by mtime order by mtime;","height":115,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false},{"id":"177813629812720","contents":"# 5. Delta값 조회","height":34,"lineHeight":19,"minimal":true,"type":"mrk","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true},{"id":"1778054038915249","contents":"--delta 값 조회 (previous)\r\nselect name,\r\n       bucket_time,\r\n       bucket_last_temp,\r\n       bucket_last_prev,\r\n       (bucket_last_temp - bucket_last_prev) as delta\r\n  from (\r\n        select name,\r\n               bucket_time,\r\n               bucket_last_temp,\r\n               lag(bucket_last_temp, 1) over (partition by name order by bucket_time) as bucket_last_prev\r\n          from (\r\n                select bucket_time,\r\n                       name,\r\n                       json_extract_double(bucket_last, '$.metrics.temperature') as bucket_last_temp\r\n                  from (\r\n                        select name,\r\n                               rollup('sec', 3, time) as bucket_time,\r\n                               last(time, value) as bucket_last\r\n                          from tag_json_delta\r\n                         where name in ('DEVICE_01', 'DEVICE_02')\r\n                           and time between '2026-05-01 09:00:00' and '2026-05-01 09:00:59'\r\n                         group by name, bucket_time\r\n                       ) r0\r\n               ) r1\r\n       ) r2\r\n order by name, bucket_time;","height":532,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false},{"id":"1778054158757229","contents":"--delta 값 조회 (next)\r\n select name,\r\n       bucket_time,\r\n       bucket_last_pressure,\r\n       bucket_last_next,\r\n       (bucket_last_pressure - bucket_last_next) as delta\r\n  from (\r\n        select name,\r\n               bucket_time,\r\n               bucket_last_pressure,\r\n               lead(bucket_last_pressure, 1) over (partition by name order by bucket_time) as bucket_last_next\r\n          from (\r\n                select bucket_time,\r\n                       name,\r\n                       json_extract_double(bucket_last, '$.metrics.pressure') as bucket_last_pressure\r\n                  from (\r\n                        select name,\r\n                               rollup('min', 5, time) as bucket_time,\r\n                               last(time, value) as bucket_last\r\n                          from tag_json_delta\r\n                         where name in ('DEVICE_01', 'DEVICE_02')\r\n                           and time between '2026-05-01 09:00:00' and '2026-05-01 09:59:00'\r\n                         group by name, bucket_time\r\n                       ) r0\r\n               ) r1\r\n       ) r2\r\n order by name, bucket_time;","height":531,"lineHeight":19,"minimal":false,"type":"sql","tqlType":null,"lang":[["markdown","Markdown"],["SQL","SQL"],["go","TQL"],["shell","Shell"]],"result":"","status":true,"brief":false}]}